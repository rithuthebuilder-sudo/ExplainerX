rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}/savedExplanations
    // Document ID: auto-generated
    // Fields:
    //   - subject: string (required) - The subject category
    //   - topic: string (required) - The topic name
    //   - level: string (required) - Beginner, Intermediate, Advanced
    //   - content: map (required) - The Gemini explanation response
    //   - createdAt: timestamp (required) - Creation time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidExplanation(data) {
      return data.keys().hasAll(['subject', 'topic', 'level', 'content', 'createdAt']) &&
             data.subject is string && data.subject.size() > 0 && data.subject.size() < 100 &&
             data.topic is string && data.topic.size() > 0 && data.topic.size() < 200 &&
             data.level in ['Beginner', 'Intermediate', 'Advanced'] &&
             data.content is map &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId}/savedExplanations/{explanationId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidExplanation(request.resource.data);
      allow delete: if isOwner(userId);
      
      // Updates are not typically needed for saved static explanations in this app, 
      // but we'll allow it if the owner maintains the schema.
      allow update: if isOwner(userId) && isValidExplanation(request.resource.data);
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
